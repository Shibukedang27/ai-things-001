APP_NAME=ResearchForge OS API
APP_VERSION=0.2.0
ENVIRONMENT=local
DEBUG=false
API_V1_PREFIX=/api/v1

DATABASE_URL=postgresql+psycopg://researchforge:researchforge_dev_password@postgres:5432/researchforge
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT=30

JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14
PASSWORD_HASH_ROUNDS=12

CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Authorization,Content-Type,X-Request-ID

RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60
SECURITY_HSTS_SECONDS=31536000
LOG_LEVEL=INFO
LOG_JSON=true

RETRIEVAL_NAMESPACE=researchforge
RETRIEVAL_COLLECTION_NAME=knowledge
RETRIEVAL_VECTOR_BACKEND=memory
RETRIEVAL_CHROMA_PERSIST_DIRECTORY=.chroma
RETRIEVAL_MAX_CONTEXT_CHARACTERS=1200
