OFFERPILOT_AI_APP_NAME=OfferPilot AI API
OFFERPILOT_AI_APP_VERSION=0.1.0
OFFERPILOT_AI_ENVIRONMENT=local
OFFERPILOT_AI_DEBUG=false

OFFERPILOT_AI_HOST=0.0.0.0
OFFERPILOT_AI_PORT=8000
OFFERPILOT_AI_API_V1_PREFIX=/api/v1
OFFERPILOT_AI_DOCS_ENABLED=true

OFFERPILOT_AI_DATABASE_URL=postgresql+asyncpg://offerpilotai:offerpilotai_change_me@localhost:5432/offerpilotai
OFFERPILOT_AI_DATABASE_POOL_SIZE=5
OFFERPILOT_AI_DATABASE_MAX_OVERFLOW=10
OFFERPILOT_AI_DATABASE_ECHO=false

OFFERPILOT_AI_REDIS_URL=redis://localhost:6379/0

OFFERPILOT_AI_CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
OFFERPILOT_AI_CORS_ALLOW_CREDENTIALS=true
OFFERPILOT_AI_CORS_ALLOW_METHODS=["GET","POST","PUT","PATCH","DELETE","OPTIONS"]
OFFERPILOT_AI_CORS_ALLOW_HEADERS=["Authorization","Content-Type","X-API-Key","X-Request-ID"]
OFFERPILOT_AI_TRUSTED_HOSTS=["localhost","127.0.0.1","testserver","*.localhost"]

OFFERPILOT_AI_AUTH_ENABLED=false
OFFERPILOT_AI_API_KEY=
OFFERPILOT_AI_JWT_SECRET_KEY=change-me-in-production
OFFERPILOT_AI_JWT_ALGORITHM=HS256
OFFERPILOT_AI_ACCESS_TOKEN_EXPIRE_MINUTES=15
OFFERPILOT_AI_REFRESH_TOKEN_EXPIRE_DAYS=30
OFFERPILOT_AI_PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30
OFFERPILOT_AI_MAX_LOGIN_ATTEMPTS=5
OFFERPILOT_AI_ACCOUNT_LOCK_MINUTES=15

OFFERPILOT_AI_LIVE_CODE_EXECUTION_ENABLED=true
OFFERPILOT_AI_LIVE_CODE_DEFAULT_TIMEOUT_SECONDS=3
OFFERPILOT_AI_LIVE_CODE_MAX_TIMEOUT_SECONDS=8
OFFERPILOT_AI_LIVE_CODE_MAX_SOURCE_CHARS=50000
OFFERPILOT_AI_LIVE_CODE_MAX_STDIN_CHARS=20000

OFFERPILOT_AI_RESUME_PDF_MAX_BYTES=5000000
OFFERPILOT_AI_RESUME_TEXT_MAX_CHARS=120000

OFFERPILOT_AI_REQUEST_ID_HEADER=X-Request-ID
OFFERPILOT_AI_LOG_LEVEL=INFO
OFFERPILOT_AI_LOG_FORMAT=json
OFFERPILOT_AI_READINESS_DATABASE_CHECK_ENABLED=true
OFFERPILOT_AI_WAIT_FOR_DATABASE=true
OFFERPILOT_AI_DATABASE_WAIT_TIMEOUT_SECONDS=60
OFFERPILOT_AI_RUN_MIGRATIONS=false
OFFERPILOT_AI_RUN_SEED=false
